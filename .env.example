# ============================================
# CRIMSON INTEGRATION (Required)
# ============================================
# Service authentication key - shared secret between Gateway (Port 4000) and Worker (Port 5100)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This MUST match the SERVICE_KEY in Crimson-Window-UI-Backend/.env
SERVICE_KEY=your_64_character_hex_string_here

# Server configuration
PORT=5100
NODE_ENV=development
CORS_ORIGIN=http://localhost:4000

# ============================================
# DATABASE (Required)
# ============================================
# PostgreSQL connection string (shared database with Gateway)
# Uses 'automation' schema to isolate tables from UI-Backend
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crimson_gateway?connection_limit=10&pool_timeout=20&connect_timeout=10

# ============================================
# BOT CREDENTIALS (Optional - Configure as needed)
# ============================================
# Used for other bots
TELEGRAM_BOT_TOKEN=123456789:ABCDEF-YOUR-BOT-TOKEN
TELEGRAM_CHAT_ID=987654321

REDDIT_ACCESS_TOKEN=your_reddit_access_token
REDDIT_USER=your_reddit_username

IG_ACCESS_TOKEN=your_instagram_graph_api_token
IG_USER_ID=17841400000000000

TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAA%2FAAAAAAAAAAAAAAAAAAAAAAA%3DAAAAAAAAAAAAAAA
TWITTER_USER_ID=1234567890

## Facebook credentials
# Single page (legacy):
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
FACEBOOK_PAGE_ID=1234567890123456

# Multiple pages (preferred):
# Option A: JSON array (recommended when you have multiple pages)
# FACEBOOK_CREDENTIALS='[{"pageId":"123...","accessToken":"EAA..."},{"pageId":"456...","accessToken":"EAA..."}]'
# Option B: Numbered env vars
# FACEBOOK_PAGE_ID_1=123...
# FACEBOOK_ACCESS_TOKEN_1=EAA...
# FACEBOOK_PAGE_ID_2=456...
# FACEBOOK_ACCESS_TOKEN_2=EAA...

GMB_ACCESS_TOKEN=your_google_my_business_access_token
GMB_ACCOUNT_ID=your_gmb_account_id

ENABLE_SMS=true
ENABLE_EMAIL=true
ENABLE_WHATSAPP=true
MAX_REMINDERS=3

# Twilio (SMS / WhatsApp) credentials
# TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN are required to use Twilio APIs.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Phone numbers in E.164 format. For WhatsApp use the Twilio sandbox number or your approved WhatsApp sender (prefix with 'whatsapp:' when used as 'to').
TWILIO_SMS_FROM=+12345551234
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Default alert recipients for admin notifications
ALERT_SMS_TO=+15559876543
ALERT_WHATSAPP_TO=+15559876543

# Twilio retry/backoff configuration
# Number of retries to attempt when a Twilio send fails
TWILIO_RETRY_COUNT=3
# Base delay in milliseconds used for exponential backoff (multiplied by 2^attempt)
TWILIO_RETRY_BASE_MS=300


# OPENAI
OPENAI_API_KEY=sk-...
ENABLE_IMAGE_GEN=true

# RunwayML
RUNWAY_API_KEY=...

# Toggles
ENABLE_BLOG_GEN=true
ENABLE_MEDIA_GEN=true

ENABLE_VIDEO_GEN=true

REDDIT_USER_AGENT=MyRedditBot/1.0.0
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
